# Posnet Caddy — reverse proxy + daxili TLS (local CA, mkcert lazım deyil)
# Host 80/443 tutulub → Caddy host 8443:443-də. Domenlər üçün hosts faylı (opsional):
#   127.0.0.1 posnet.local keycloak.posnet.local mail.posnet.local s3.posnet.local \
#             console.posnet.local grafana.posnet.local jaeger.posnet.local
# Qeyd: bütün servislər birbaşa localhost portlarında da əlçatandır (Caddy opsional rahatlıqdır).
{
	local_certs
	auto_https disable_redirects
}

# Hub core API — AI-1-də gələcək (hələlik placeholder)
posnet.local {
	respond "Posnet Hub — core API AI-1-də əlavə olunacaq (dev)" 200
}

keycloak.posnet.local {
	reverse_proxy keycloak:8080
}

mail.posnet.local {
	reverse_proxy mailpit:8025
}

s3.posnet.local {
	reverse_proxy minio:9000
}

console.posnet.local {
	reverse_proxy minio:9001
}

grafana.posnet.local {
	reverse_proxy grafana:3000
}

jaeger.posnet.local {
	reverse_proxy jaeger:16686
}
