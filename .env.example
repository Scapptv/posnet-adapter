# Posnet — Environment Variables Template
# Real .env faylına KOPYALA və placeholder dəyərləri SİRR-LƏRİN ƏVƏZİNƏ vault://path REF-İ İLƏ doldur.
# QAYDA: Heç bir real sirr bu fayla yazılmasın. .env .gitignore-dadır.

# ---- App ----
APP_ENV=development           # development | staging | production
APP_NAME=posnet-core
APP_VERSION=0.1.0a0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
APP_LOG_FORMAT=json           # json | console
APP_DEBUG=false

# ---- Country / Locale ----
COUNTRY_DEFAULT=AZ            # AZ | TR
LOCALE_DEFAULT=az_AZ
TIMEZONE_DEFAULT=Asia/Baku

# ---- Database ----
# Lokal dev: docker-compose postgres servisi
# Prod: vault://secret/posnet/db/{env}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=posnet
POSTGRES_PASSWORD=<vault://secret/posnet/db/password>
POSTGRES_DB=posnet_core
DATABASE_URL=postgresql+psycopg://posnet:CHANGE_ME@postgres:5432/posnet_core
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600
# Non-owner role each request switches into (SET LOCAL ROLE) so RLS enforces
# tenant isolation (ADR-0013/0015). Created by migration 0002.
DATABASE_APP_ROLE=posnet_app

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---- Vault ----
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=<offline-saxlanılır>      # Lokal dev: dev-root-token; prod: KMS auto-unseal
VAULT_NAMESPACE=
VAULT_MOUNT=secret

# ---- Keycloak (Auth) ----
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=posnet
# Foundation: api-gateway is bearer-only (validates tokens via JWKS), holds NO
# secret (ADR-0014). CLIENT_SECRET is only for a future confidential flow
# (BFF/token-exchange) and its prod value is written to Vault at G7.
KEYCLOAK_CLIENT_ID=api-gateway
# KEYCLOAK_CLIENT_SECRET=<vault://secret/posnet/keycloak/api-gateway>  # confidential flow only (G7)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<offline>
JWKS_CACHE_TTL_SECONDS=3600
# Comma-separated audiences the API enforces; empty = skip aud check (foundation
# default — enable with a realm audience mapper for production, ADR-0014).
KEYCLOAK_AUDIENCES=

# ---- OpenTelemetry ----
OTEL_SERVICE_NAME=posnet-core
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0          # Lokal 1.0; prod 0.1

# ---- pgmq ----
PGMQ_QUEUE_DEFAULT=posnet_events
PGMQ_DLQ_DEFAULT=posnet_events_dlq
PGMQ_VISIBILITY_TIMEOUT=30
PGMQ_MAX_RETRY=5

# ---- Rate Limiter ----
RATE_LIMIT_PER_TENANT=100/minute
RATE_LIMIT_WEBHOOK_PER_CHANNEL=10/second
RATE_LIMIT_STORAGE=redis

# ---- CORS ----
CORS_ALLOW_ORIGINS=https://admin.posnet.local,https://posnet.local
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# ---- Object Storage (MinIO lokal / S3 prod) ----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=<vault://secret/posnet/s3/access_key>
S3_SECRET_KEY=<vault://secret/posnet/s3/secret_key>
S3_BUCKET_UPLOADS=posnet-uploads
S3_BUCKET_BACKUPS=posnet-backups
S3_REGION=us-east-1

# ---- Email (Mailpit lokal) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@posnet.local
SMTP_USE_TLS=false

# ---- Feature Flags ----
FEATURE_FLAGS_CACHE_TTL=60

# ---- Health probes ----
HEALTH_CHECK_TIMEOUT=5

# ---- Cloud (AI-7+, prod) ----
# CLOUD_PROVIDER=digitalocean
# CLOUD_REGION=fra1
